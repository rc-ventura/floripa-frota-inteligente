# URL de conexão do banco consolidado (spec 002).
# Ausente → default: sqlite:///db/frota.db (dev local).
# Demo (PostgreSQL 16, spec 007):
#   DATABASE_URL=postgresql+psycopg://postgres:frota@localhost:5432/frota
# DATABASE_URL=sqlite:///db/frota.db

# Pipeline ETL (spec 003) — fontes e caminhos (contrato ciclo_pipeline.md).
# Ausentes → defaults do layout do repositório.
# Demo em compose (spec 007): MULTAS_API_URL=http://fake_api:8000
# PIPELINE_INBOX=data/inbox
# MULTAS_API_URL=http://localhost:8000
# PIPELINE_XLSX_MANUTENCAO=data/seeds/manutencao.xlsx
# PIPELINE_SQLITE_LICENCIAMENTO=data/seeds/licenciamento.sqlite
# PIPELINE_CADASTRO_VEICULOS=data/seeds/veiculos.json

# Agendador da spec 004 — ciclo único ETL → Motor (contrato ciclo_pipeline.md + spec 004).
# Intervalo em segundos entre ciclos completos. Default 90 (1,5 min) — compatível com
# duração < 1s do ETL no volume da PoC (SC-004 spec 003) e com a demo ao vivo.
# Demo: 60 para resposta mais rápida; produção: 300+ para reduzir carga.
# CICLO_INTERVALO_SEGUNDOS=90